# lastdays is zero-config by default. Every key below is OPTIONAL.
# Precedence: process env > ./.env > ~/.config/lastdays/.env > macOS keychain (lastdays-<KEY>).

# Raise the GitHub search rate limit (keyless works but is ~10 req/min):
# GITHUB_TOKEN=ghp_xxx

# Optional engine-side reasoning provider. Default is "local" = the agent host
# (Claude Code / Codex) is the LLM, so you normally need NONE of these.
# OpenAI prefers a ChatGPT/Codex subscription token (~/.codex/auth.json) over a key.
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# LASTDAYS_OPENAI_PREFER_KEY=1   # force the paid OpenAI key instead of the Codex subscription token

# Bilibili is LIVE and keyless (anonymous buvid3 + wbi sign). BILI_COOKIE is
# OPTIONAL - only set it if the anonymous path hits 风控 (-412):
# BILI_COOKIE=buvid3=xxx; SESSDATA=xxx

# Douyin is LIVE and keyless (public hot-search board; no cookie needed).
# Other Chinese sources are engine stubs today (agent covers them via WebSearch):
# WEIBO_SUB=xxx
# XHS_COOKIE=xxx
# ZHIHU_COOKIE=xxx
